---
layout: layouts/home.njk
---

<div class="hero bg-base-200 min-h-screen">
    <div class="hero-content text-center">
        <div class="max-w-md">
            <h1 class="text-5xl font-bold">Thomas Cicognani</h1>
            <h2 class="text-2xl">"Zhykos"</h2>
            <ul class="mt-6 mb-6 flex flex-col gap-2 text-s">
                <li>
                    <img height="8"
                         width="8"
                         class="size-4 me-2 inline-block text-success"
                         src="{{ "check" | icon('boxicons', 'regular') }}"
                         alt="" />
                    <span>Développeur fullstack</span>
                </li>
                <li>
                    <img height="8"
                         width="8"
                         class="size-4 me-2 inline-block text-success"
                         src="{{ "check" | icon('boxicons', 'regular') }}"
                         alt="" />
                    <span>Java / Spring Boot / TypeScript / React (Native) / Vue</span>
                </li>
                <li>
                    <img height="8"
                         width="8"
                         class="size-4 me-2 inline-block text-success"
                         src="{{ "check" | icon('boxicons', 'regular') }}"
                         alt="" />
                    <span>Entousiaste de Deno</span>
                </li>
                <li>
                    <img height="8"
                         width="8"
                         class="size-4 me-2 inline-block text-success"
                         src="{{ "check" | icon('boxicons', 'regular') }}"
                         alt="" />
                    <span>Open Source</span>
                </li>
                <li>
                    <img height="8"
                         width="8"
                         class="size-4 me-2 inline-block text-success"
                         src="{{ "check" | icon('boxicons', 'regular') }}"
                         alt="" />
                    <span>Chroniqueur jeux vidéo</span>
                </li>
            </ul>
            <div>
                <div class="avatar">
                    <div class="ring-primary ring-offset-base-100 w-8 rounded-full ring-2 ring-offset-2 mx-4">
                        <a href="https://www.linkedin.com/in/thomas-cicognani" class="link">
                            <img height="8"
                                 width="8"
                                 src="{{ "linkedin" | icon('boxicons', 'logos') }}"
                                 alt="LinkedIn"
                                 title="Ouvrir ma page LinkedIn" />
                        </a>
                    </div>
                </div>
                <div class="avatar">
                    <div class="ring-primary ring-offset-base-100 w-8 rounded-full ring-2 ring-offset-2 mx-4">
                        <a href="https://www.github.com/zhykos" class="link">
                            <img height="8"
                                 width="8"
                                 src="{{ "github" | icon('boxicons', 'logos') }}"
                                 alt="GitHub"
                                 title="Ouvrir ma page GitHub" />
                        </a>
                    </div>
                </div>
                <div class="avatar">
                    <div class="ring-primary ring-offset-base-100 w-8 rounded-full ring-2 ring-offset-2 mx-4">
                        <a href="mailto:contact@thomascicognani.mailer.me">
                            <img height="8"
                                 width="8"
                                 src="{{ "envelope" | icon('boxicons', 'regular') }}"
                                 alt="Email"
                                 title="M'envoyer un email" />
                        </a>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <a href="/about" class="link btn">
                    <img height="16"
                         width="16"
                         src="{{ "question-mark" | icon('boxicons', 'regular') }}"
                         alt="" />
