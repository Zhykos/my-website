{% for post in postslist %}
    <article>
        <div class="flex flex-col gap-6 bg-base-200 rounded-box p-6 m-6">
            <div class="flex">
                <a class="text-2xl font-bold link" href={{ post.url }}>{{ post.title }}</a>
            </div>
            <div class="flex justify-between items-center">
                <time class="text-sm" datetime="{{ post.date | date("DATETIME") }}">
                    {{ post.date | date('HUMAN_DATE', 'fr') }}
                </time>
                <span class="post-tags">
                    {% for tag in post.tags %}<div class="badge badge-primary m-1">{{ tag }}</div>{% endfor %}
                </span>
            </div>
            <div class="flex">
                <span>{{ post.content | truncate | safe }}</span>
            </div>
        </div>
    </article>
{% endfor %}
