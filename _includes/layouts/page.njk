---
layout: layouts/base.njk
bodyClass: body-post
---

<section data-pagefind-body>
    <div class="m-8">{{ content | safe }}</div>
</section>
<footer class="footer sm:footer-horizontal bg-base-200 text-base-content p-10">
    <nav>
        <h6 class="footer-title">Professionnel</h6>
        <a class="link" href="/about">À propos</a>
        <a class="link" href="/education">Scolarité et formations</a>
        <a class="link" href="/professional">Expériences professionnelles</a>
        <a class="link" href="/skills">Skills</a>
        <a class="link" href="/files/thomas-cicognani-resume.pdf">CV</a>
        <a class="link" href="/files/thomas-cicognani-complete-resume.pdf">CV exhaustif</a>
    </nav>
    <nav>
        <h6 class="footer-title">Personnel</h6>
        <a class="link" href="/personal">Projets Open source</a>
        <a class="link" href="/">Expériences dans le jeu vidéo</a>
        <a class="link" href="/">Bénévolat, sports, etc.</a>
    </nav>
    <nav>
        <h6 class="footer-title">Blog</h6>
        <a class="link" href="/blog">Accueil de mon blog</a>
        {% set postslist = search.pages("type=posts", "date=desc", 3) %}
        {% for post in postslist %}<a href="{{ post.url }}" class="link">{{ post.title }}</a>{% endfor %}
    </nav>
</footer>
