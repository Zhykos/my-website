---
layout: layouts/base.njk
bodyClass: body-tag
---

<h1>{{ title }}</h1>
{% set postslist = results %}
{% include "templates/postslist.njk" %}
<hr />
<nav class="post-navigation">
    <ul>
        {%- if pagination.previous %}
            <li>
                <a class="link" href="{{ pagination.previous }}" rel="prev">← Previous</a>
            </li>
        {% endif %}
        <li>Page {{ pagination.page }}</li>
        {%- if pagination.next %}
            <li>
                <a class="link" href="{{ pagination.next }}" rel="next">Next →</a>
            </li>
        {% endif %}
    </ul>
</nav>
