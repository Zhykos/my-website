import React from 'react';

import Game from "../../components/game-item"
import primaryLocalImg from '../../images/compress/{{componentName}}.webp';
import coverLocalImg from '../../images/compress/{{componentName}}-cover.webp';

const {{componentName}} = () => {
  return (
    <Game
      name="{{name}}"
      releaseYear="{{releaseYear}}"
      igdbURL="{{{igdbURL}}}"
      platformVersion="{{platformVersion}}"
      platformPlayedOn="{{{platformPlayedOn}}}"
      flickrURL="{{flickrURL}}"
      version="{{version}}"
      countPhotos="{{countPhotos}}"
      countVideos="{{countVideos}}"
      primaryLocalImg={primaryLocalImg}
      coverLocalImg={coverLocalImg}
    />
  );
};

export default {{componentName}};