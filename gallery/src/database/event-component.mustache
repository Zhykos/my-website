import React from 'react';
import Event from "../../components/event-item"

const {{componentName}} = () => {
  return (
    <Event
      name="{{title}}"
      year="{{year}}"
      country="{{country}}"
      city="{{city}}"
      flickrURL="{{{url}}}"
      countPhotos="{{countPhotos}}"
      countVideos="{{countVideos}}"
      primaryPhotoURL="{{{primaryPhotoURL}}}" />
