---
layout: layouts/page.njk
---

{% import "macro-breadcrumbs.njk" as breadcrumbs %}
{{ breadcrumbs.breadcrumbs2('Blog', '/blog') }}
<div class="card bg-base-300 rounded-box grid h-16 grow place-items-center font-bold">Bienvenue sur mon blog</div>
{% set postslist = search.pages("type=posts pinned=true", "date=desc", 3) %}
{% if postslist.length %}
    <div class="divider divider-primary divider-start">Les articles épinglés</div>
    {% include "templates/posts-list-extract-pinned.njk" %}
{% endif %}
<div class="divider divider-primary divider-start">Les derniers articles</div>
{% set postslist = search.pages("type=posts pinned!=true", "date=desc", 3) %}
{% include "templates/posts-list-extract.njk" %}
<div class="flex text-center">
    <nav class="flex-1">
        <button class="btn btn-ghost">
            <a class="link text-xl" href="/posts/">&gt; Tous les articles &lt;</a>
        </button>
    </nav>
</div>
